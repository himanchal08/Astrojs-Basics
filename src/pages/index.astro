---
import DecoratoryPill from '../components/ui/Pill.astro';
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import * as prismic from '@prismicio/client';
import IvyleagueCard from '../components/ui/IvyleagueCard.astro';
import FAQ from '../components/structure/FAQ.astro';

import { getSingleDoc } from '../lib/prismic';

import StackingCards from '../components/islands/StackingCard';

const cards = [
  {
    title: "Drill Sessions & Lectures Weekly",
    description: "In addition to weekly classes, students will engage in practice and small seminar-style learning sessions focusing on collapsing, weighing, and more!",
  },
  {
    title: "90-Minute Weekly Classes",
    description: "Our weekly 90-minute classes are the core of the NDC program. Taught by the same teacher all season, each group is kept to four to six students.",
  },
  {
    title: "No Tournament Upcharges",
    description: "We provide tournament services at cost, meaning we do not profit from competitions. Online tournaments range from $125–$200, in-person from $750–$1500.",
  },
  {
    title: "All Team Practices (New)",
    description: "Bi-weekly sessions open to every NDC member. Large-format sessions designed to build team cohesion with a 6:1 student-to-coach ratio.",
  },
  {
    title: "Smallest Student to Teacher Ratio",
    description: "Each group is kept to four to six students maximum, ensuring every debater gets real, individualized feedback on their performance.",
  },
];

const home = await getSingleDoc('home');
const data = home.data;
const faqItems = [
  {
    question: 'How do online classes work?',
    answer:
      'Classes run live with expert coaches, small groups, and guided practice rounds. Students get structured feedback each week.'
  },
  {
    question: 'Which age groups can join Civic Debate Academy?',
    answer:
      'Programs are available for middle school and high school students, with track placement based on experience level.'
  },
  {
    question: 'Do you help with tournament preparation?',
    answer:
      'Yes. We train students for case strategy, rebuttals, cross-examination, and confidence under real tournament timing.'
  },
  {
    question: 'Need help choosing the right class?',
    answer: 'Our team can recommend the right starting path for your student. CLICK HERE to schedule a free placement call.',
    highlighted: true
  }
];
---

<Layout>
<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 text-center flex flex-col items-center gap-8">

  <DecoratoryPill text="America's #1 Ranked" />
	<!-- can make </H1> a component too -->
  <h1 class=" text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl">
    <span>{prismic.asText(data.homepage_title_before)} </span>
    <span class="text-[#7B1C3E] italic">{prismic.asText(data.homepage_title_highlited)}</span>
    <span> {prismic.asText(data.homepage_title_after)}</span>
  </h1>

  <p class=" mx-auto max-w-2xl text-lg leading-8 text-gray-600">
    {prismic.asText(data.lead_para)}
    
  </p>

  <div class=" flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
    <Button href="#" variant="primary" size="sm" class="px-6 uppercase tracking-wider">
      Schedule a Consultation
    </Button>
    <Button href="#" variant="secondary" size="sm" class="px-6 uppercase tracking-wider">
      View Our Class Schedule
    </Button>
  </div >

  <div >
  <IvyleagueCard
  title="Ivy League Success"
  description="Our students are consistently accepted to top-tier universities. Debate has proven to be one of the strongest predictors of college admissions, showcasing critical thinking, communication skills, and leadership that top schools value."
  logos={[
    { src: "/logos/harvard.png", alt: "Harvard University" },
    { src: "/logos/chicago.png", alt: "The University of Chicago" },
    { src: "/logos/princeton.png", alt: "Princeton University" },
    { src: "/logos/vanderbilt.png", alt: "Vanderbilt University" },
  ]}
/>
</div>
<div>
{prismic.asText(data.section_h2)}
</div>

</section>

<section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
  <FAQ pill="Common Questions" title="FAQs From Parents & Students" items={faqItems} />
</section>

<section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 gap-16 lg:grid-cols-2">

    <div class="flex flex-col justify-start pt-4 lg:sticky lg:top-24 lg:self-start">
      <h2 class="text-4xl font-bold leading-tight text-(--color-charcoal)">
        A Tailored Program to Make Top Debate Champions.
      </h2>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button href="#" variant="primary" size="sm" class="px-6 uppercase tracking-wider">
          Schedule a Consultation
        </Button>
        <Button href="#" variant="secondary" size="sm" class="px-6 uppercase tracking-wider">
          View Our Class Schedule
        </Button>
      </div>
    </div>
    <StackingCards client:load cards={cards} />

  </div>
</section>
</Layout>
