---
const {
  text = '',
  class: className = '',
  ...rest
} = Astro.props;

const baseClasses = `
bg-[var(--pill-color-bg)] 
text-[var(--pill-color-text)] 
border-[1.6px] border-[var(--btn-secondary-border)]
shadow-[2px_2px_0_var(--btn-secondary-shadow)]
px-3 py-1 rounded-[8px] text-sm font-medium
w-fit
`;

const classes = [baseClasses, className].filter(Boolean).join(' ');
---

<div class={classes} {...rest}>
  {text}
</div>