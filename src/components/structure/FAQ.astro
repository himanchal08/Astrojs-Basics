---

import DecoratoryPill from '../ui/Pill.astro';
import FAQAccordion from '../islands/FAQAccordion.tsx';

interface FAQItem {
  question: string
  answer: string
  highlighted?: boolean
}

interface Props {
  pill?: string
  title?: string
  items: FAQItem[]
}

const { title = "Frequently Asked Questions", items, pill } = Astro.props as Props
const regular = items.filter(i => !i.highlighted)
---

<section class="px-4 py-16">

  {pill && (
    <DecoratoryPill text={pill} />
  )}

  <!-- Title -->
  <h2 class="mt-4 text-3xl font-bold text-(--color-charcoal)">{title}</h2>

  <div class="mt-8 flex flex-col gap-6 lg:flex-row">
    <FAQAccordion client:visible items={regular} />
  </div>

</section>
